# ============================================================
# IoT Drainage Monitoring System — .gitignore
# ============================================================

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# --- Node.js / Next.js Dashboard ---
node_modules/
.next/
.vercel/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# --- Environment variables (keep secrets out of git) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Arduino / PlatformIO build artefacts ---
.pio/
.pioenvs/
.piolibdeps/
*.o
*.d
*.elf
*.bin
*.hex

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Editor / IDE ---
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# --- Temporary files ---
*.tmp
*.temp
