{
    "title": "Smart Drainage System (Perfect UI)",
    "image": null,
    "mobileHide": false,
    "mobileOrder": null,
    "configuration": {
        "description": "Final Dashboard with Graphs, Status Cards, and Alarm Logs.",
        "widgets": {
            "widget_1_flow": {
                "isSystemType": true,
                "bundleAlias": "charts",
                "typeAlias": "basic_timeseries",
                "type": "timeseries",
                "title": "Flow Rate Trends (L/min)",
                "sizeX": 12,
                "sizeY": 8,
                "row": 0,
                "col": 0,
                "config": {
                    "datasources": [
                        {
                            "type": "entity",
                            "name": "Drainage Node",
                            "entityAliasId": "alias_drainage_node",
                            "dataKeys": [
                                {
                                    "name": "flow_lpm",
                                    "type": "timeseries",
                                    "label": "Flow Rate",
                                    "color": "#4caf50",
                                    "units": "L/min"
                                }
                            ]
                        }
                    ],
                    "timewindow": {
                        "realtime": {
                            "interval": 1000,
                            "timewindowMs": 300000
                        }
                    },
                    "showTitle": true,
                    "backgroundColor": "#fff",
                    "settings": {
                        "showLegend": true,
                        "legendConfig": {
                            "position": "bottom"
                        },
                        "yaxis": {
                            "title": "L/min"
                        }
                    }
                }
            },
            "widget_2_level": {
                "isSystemType": true,
                "bundleAlias": "charts",
                "typeAlias": "basic_timeseries",
                "type": "timeseries",
                "title": "Water Level Trends (cm)",
                "sizeX": 12,
                "sizeY": 8,
                "row": 0,
                "col": 12,
                "config": {
                    "datasources": [
                        {
                            "type": "entity",
                            "name": "Drainage Node",
                            "entityAliasId": "alias_drainage_node",
                            "dataKeys": [
                                {
                                    "name": "water_level_cm",
                                    "type": "timeseries",
                                    "label": "Water Level",
                                    "color": "#2196f3",
                                    "units": "cm"
                                }
                            ]
                        }
                    ],
                    "timewindow": {
                        "realtime": {
                            "interval": 1000,
                            "timewindowMs": 300000
                        }
                    },
                    "showTitle": true,
                    "backgroundColor": "#fff",
                    "settings": {
                        "showLegend": true,
                        "legendConfig": {
                            "position": "bottom"
                        },
                        "yaxis": {
                            "max": 50,
                            "title": "cm"
                        }
                    }
                }
            },
            "widget_3_rise": {
                "isSystemType": true,
                "bundleAlias": "charts",
                "typeAlias": "basic_timeseries",
                "type": "timeseries",
                "title": "Rise Rate Analysis (cm/min)",
                "sizeX": 12,
                "sizeY": 6,
                "row": 8,
                "col": 0,
                "config": {
                    "datasources": [
                        {
                            "type": "entity",
                            "name": "Drainage Node",
                            "entityAliasId": "alias_drainage_node",
                            "dataKeys": [
                                {
                                    "name": "rise_rate_cm_per_min",
                                    "type": "timeseries",
                                    "label": "Rise Rate",
                                    "color": "#FF9800",
                                    "units": "cm/min"
                                }
                            ]
                        }
                    ],
                    "timewindow": {
                        "realtime": {
                            "interval": 1000,
                            "timewindowMs": 300000
                        }
                    },
                    "showTitle": true,
                    "backgroundColor": "#fff",
                    "settings": {
                        "showLegend": true
                    }
                }
            },
            "widget_4_eta": {
                "isSystemType": true,
                "bundleAlias": "cards",
                "typeAlias": "simple_card",
                "type": "latest",
                "title": "Overflow ETA",
                "sizeX": 6,
                "sizeY": 6,
                "row": 8,
                "col": 12,
                "config": {
                    "datasources": [
                        {
                            "type": "entity",
                            "name": "Drainage Node",
                            "entityAliasId": "alias_drainage_node",
                            "dataKeys": [
                                {
                                    "name": "overflow_eta_min",
                                    "type": "timeseries",
                                    "label": "ETA",
                                    "color": "#FFC107",
                                    "decimals": 1
                                }
                            ]
                        }
                    ],
                    "showTitle": true,
                    "backgroundColor": "#fff",
                    "settings": {
                        "label": "Minutes",
                        "units": "min",
                        "showLabel": true
                    }
                }
            },
            "widget_5_state": {
                "isSystemType": true,
                "bundleAlias": "cards",
                "typeAlias": "html_card",
                "type": "latest",
                "title": "Current State",
                "sizeX": 6,
                "sizeY": 6,
                "row": 8,
                "col": 18,
                "config": {
                    "datasources": [
                        {
                            "type": "entity",
                            "name": "Drainage Node",
                            "entityAliasId": "alias_drainage_node",
                            "dataKeys": [
                                {
                                    "name": "state",
                                    "type": "timeseries",
                                    "label": "State",
                                    "color": "#000"
                                },
                                {
                                    "name": "alert_level",
                                    "type": "timeseries",
                                    "label": "Level",
                                    "color": "#d32f2f"
                                }
                            ]
                        }
                    ],
                    "showTitle": true,
                    "backgroundColor": "#fff",
                    "settings": {
                        "cardHtml": "<div style='text-align:center; height:100%; display:flex; flex-direction:column; justify-content:center;'>\n<div style='font-size:18px; font-weight:bold; margin-bottom:10px;'>${state}</div>\n<div style='font-size:14px; color:${alert_level:color}; font-weight:bold; border: 2px solid ${alert_level:color}; padding: 5px; border-radius: 5px;'>${alert_level}</div>\n</div>"
                    }
                }
            },
            "widget_7_alarms": {
                "isSystemType": true,
                "bundleAlias": "alarm_widgets",
                "typeAlias": "alarms_table",
                "type": "alarm",
                "title": "System Alarm Log",
                "sizeX": 24,
                "sizeY": 6,
                "row": 14,
                "col": 0,
                "config": {
                    "datasources": [
                        {
                            "type": "entity",
                            "name": "Drainage Node",
                            "entityAliasId": "alias_drainage_node"
                        }
                    ],
                    "alarmSource": {
                        "type": "entity",
                        "entityAliasId": "alias_drainage_node"
                    },
                    "alarmStatus": "ANY",
                    "alarmsPollingInterval": 1000,
                    "showTitle": true,
                    "backgroundColor": "#fff",
                    "settings": {
                        "columns": [
                            {
                                "name": "createdTime",
                                "title": "Time",
                                "dateFormat": "YYYY-MM-DD HH:mm:ss"
                            },
                            {
                                "name": "type",
                                "title": "Alarm Type"
                            },
                            {
                                "name": "severity",
                                "title": "Severity"
                            },
                            {
                                "name": "status",
                                "title": "Status"
                            }
                        ],
                        "defaultSortOrder": "createdTimeDesc"
                    }
                }
            }
        },
        "states": {
            "default": {
                "name": "Dashboard",
                "root": true,
                "layouts": {
                    "main": {
                        "widgets": {
                            "widget_1_flow": {
                                "sizeX": 12,
                                "sizeY": 8,
                                "row": 0,
                                "col": 0
                            },
                            "widget_2_level": {
                                "sizeX": 12,
                                "sizeY": 8,
                                "row": 0,
                                "col": 12
                            },
                            "widget_3_rise": {
                                "sizeX": 12,
                                "sizeY": 6,
                                "row": 8,
                                "col": 0
                            },
                            "widget_4_eta": {
                                "sizeX": 6,
                                "sizeY": 6,
                                "row": 8,
                                "col": 12
                            },
                            "widget_5_state": {
                                "sizeX": 6,
                                "sizeY": 6,
                                "row": 8,
                                "col": 18
                            },
                            "widget_7_alarms": {
                                "sizeX": 24,
                                "sizeY": 6,
                                "row": 14,
                                "col": 0
                            }
                        },
                        "gridSettings": {
                            "backgroundColor": "#eeeeee",
                            "columns": 24,
                            "margin": 10
                        }
                    }
                }
            }
        },
        "entityAliases": {
            "alias_drainage_node": {
                "id": "alias_drainage_node",
                "alias": "Drainage Sensor Node",
                "filter": {
                    "type": "deviceType",
                    "resolveMultiple": false,
                    "deviceType": "default",
                    "deviceNameFilter": ""
                }
            }
        }
    }
}